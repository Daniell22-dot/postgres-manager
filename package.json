{
  "name": "postgres-manager",
  "version": "1.0.0",
  "description": "Fast PostgreSQL manager for 20+ databases",
  "main": "src/main/index.js",
  "author": "Daniel Manyasa",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron . --dev",
    "build:renderer": "vite build",
    "build:electron": "electron-builder",
    "build": "npm run build:renderer && npm run build:electron",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.0",
    "electron-store": "^8.1.0",
    "pg": "^8.11.3",
    "pg-cursor": "^2.10.0",
    "sqlite3": "^5.1.6",
    "better-sqlite3": "^9.2.2",
    "crypto-js": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7",
    "react-window": "^1.8.10",
    "monaco-editor": "^0.45.0",
    "@monaco-editor/react": "^4.6.0",
    "react-hot-toast": "^2.4.1",
    "lucide-react": "^0.309.0"
  },
  "devDependencies": {
    "electron": "^27.1.0",
    "electron-builder": "^24.6.4",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.0.2",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.postgres.postgresmanager",
    "productName": "Postgres Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "database/**/*",
      "build/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    }
  }
}